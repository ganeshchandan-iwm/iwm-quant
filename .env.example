# Token required to read stored contact submissions via GET /api/contact
# (send it as the `x-admin-token` request header)
ADMIN_TOKEN=change-me-to-a-long-random-string

# --- Production database (required on Vercel / serverless) ---
# Local dev works with zero config (SQLite file in ./data).
# For production, create a free DB at https://turso.tech, then:
#   turso db create iwm-quant
#   turso db show iwm-quant --url        -> TURSO_DATABASE_URL
#   turso db tokens create iwm-quant     -> TURSO_AUTH_TOKEN
# and set both below (and in Vercel → Project → Settings → Environment Variables).
# TURSO_DATABASE_URL=libsql://iwm-quant-<org>.turso.io
# TURSO_AUTH_TOKEN=
